{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Refine",
  "version": "0.1.0",
  "identifier": "com.refine.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Refine",
        "width": 680,
        "height": 340,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "Refine",
        "url": "/settings",
        "width": 750,
        "height": 500,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": null,
      "frameworks": [],
      "minimumSystemVersion": "10.13"
    }
  }
}
