{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Refine",
  "version": "0.1.8",
  "identifier": "com.refine",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Refine",
        "width": 680,
        "height": 340,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "Refine",
        "url": "/settings",
        "width": 750,
        "height": 500,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true,
        "visible": false
      },
      {
        "label": "toast",
        "title": "",
        "url": "/toast",
        "width": 200,
        "height": 44,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false
      },
      {
        "label": "clipboard",
        "title": "Refine Clipboard",
        "url": "/clipboard",
        "width": 680,
        "height": 420,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https: ws://localhost:* ws://127.0.0.1:* http://localhost:11434 http://127.0.0.1:11434; media-src 'self' data: blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible",
    "macOS": {
      "entitlements": "entitlements.plist",
      "exceptionDomain": null,
      "frameworks": [],
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCMDNGMjlCRTVEQkU3NDEKUldSQjU5dmxtL0lEcXh3aGNNMFdjZlJiTVIwTStOMDcwK2NOalI4czBRU2dNaXBjS3BkL1Z5VG0K",
      "endpoints": [
        "https://github.com/aymenn8/refine-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
